# ── Required ──────────────────────────────────────────────────────────
# At least one provider key is needed. GROQ is free and the default fallback.
GROQ_API_KEY=gsk_your_groq_key_here

# ── Encryption key for API keys stored in PostgreSQL ──────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# setup.sh / setup.bat generate this automatically on first run.
FERNET_SECRET=

# ── Optional providers ─────────────────────────────────────────────────
# Add any of these to unlock that provider's models in litellm_config.yaml
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GEMINI_API_KEY=AIza_your_gemini_key_here

# ── Infrastructure (defaults match docker-compose.yml) ───────────────
DATABASE_URL=postgresql://litellm:litellm_password@localhost:5432/litellm_logs
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
LITELLM_PROXY_URL=http://localhost:4000

# ── Langfuse (optional — LLM observability traces) ──────────────────
# Get free keys at https://cloud.langfuse.com → Settings → API Keys
# Leave blank to disable. Self-hosted: set LANGFUSE_HOST to your instance.
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
